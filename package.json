{
  "name": "cupibot",
  "version": "1.0.0",
  "description": "CupiBot - Tinder and Bumble automation with AI filtering and chat",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:desktop": "tsc --noEmit -p tsconfig.desktop.json",
    "setup": "sh scripts/setup-config.sh",
    "pretest": "npm run setup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "install:local": "sh scripts/install-local.sh",
    "postinstall": "node node_modules/electron/install.js",
    "desktop:dev": "electron-vite dev",
    "desktop:build": "tsc && electron-vite build",
    "desktop:dist": "npm run desktop:build && electron-builder --config electron-builder.yml",
    "prepare": "husky"
  },
  "type": "module",
  "license": "AGPL-3.0-only",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinAndrey96/cupibot.git"
  },
  "homepage": "https://github.com/KevinAndrey96/cupibot",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "howler": "^2.2.4",
    "playwright": "^1.50.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.7",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}

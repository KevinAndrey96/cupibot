# ═══════════════════════════════════════════════════════════════════════════
# CupiBot - fuente de verdad de configuración
# Copia este archivo a .env y ajusta los valores que necesites.
# Prompts de chat/openers/contexto: config/ai/{AI_LANGUAGE}/
# Filtros generales (género, cuerpo, nombres, belleza): config/ai/ (inglés, modelo de visión)
# ═══════════════════════════════════════════════════════════════════════════

# ── Browser ────────────────────────────────────────────────────────────────

# true = sin ventana | false = ves el navegador (recomendado para login)
HEADLESS=false

# ── AI / Ollama ─────────────────────────────────────────────────────────────

# URL del servidor de inferencia (Ollama) - se levanta automáticamente si no está corriendo
OLLAMA_URL=http://127.0.0.1:11434

# Modelo para swipe: visión - filtra perfiles (llava:7b, se descarga solo si falta)
SWIPE_MODEL=llava:7b

# Modelo para chat: conversación natural (qwen2.5:7b | alternativa: llama3.1:8b)
CHAT_MODEL=qwen2.5:7b

# Idioma de prompts y reglas de AI (carpeta config/ai/{idioma}/)
AI_LANGUAGE=espanol

# Activar/desactivar filtros de AI (visión en config/ai/, chat en config/ai/{AI_LANGUAGE}/)
# Timeout del informe AI en modo Análisis (ms)
ANALYSIS_TIMEOUT_MS=180000
GENDER_FILTER_ENABLED=true
BEAUTY_FILTER_ENABLED=true

# Score mínimo de belleza para dar like (1-10) - única fuente para minScore
BEAUTY_MIN_SCORE=8

# ── Swipe session ──────────────────────────────────────────────────────────

# Rango de swipes por sesión
TINDER_MIN_SWIPES=100
TINDER_MAX_SWIPES=150
BUMBLE_MIN_SWIPES=100
BUMBLE_MAX_SWIPES=150

# Enviar opener automático al hacer match
SEND_OPENER_ON_MATCH_TINDER=true
SEND_OPENER_ON_MATCH_BUMBLE=false

# Qué hacer si no se puede extraer el perfil: like | pass
ON_EXTRACT_FAILURE=pass

# ── Swipe timing ───────────────────────────────────────────────────────────

# Pausa mínima/máxima entre swipes (ms) - 0 = sin espera
MIN_DELAY_MS=0
MAX_DELAY_MS=0

# Pausa al terminar un lote de swipes (ms)
BATCH_PAUSE_MIN_MS=0
BATCH_PAUSE_MAX_MS=0

# Swipes por lote antes de la pausa (valores altos = casi nunca pausa)
BATCH_SIZE_MIN=9999
BATCH_SIZE_MAX=9999

# Cooldown fijo entre swipes (ms) - 0 = desactivado
SWIPE_COOLDOWN_MS=0

# Delay aleatorio antes de swipear, simula "ver" el perfil (ms)
VIEWING_DELAY_MAX_MS=0

# Pausas de descanso aleatorias durante la sesión (ms)
REST_BREAK_MIN_MS=0
REST_BREAK_MAX_MS=0

# Espera al volver a swipes después de un chat break (ms)
CHAT_BREAK_RESUME_MS=0

# Cada cuántos swipes pausa para chatear (solo modo 4: Swipe + Chat)
CHAT_BREAK_INTERVAL=10

# ── Chat ───────────────────────────────────────────────────────────────────

# true = genera mensajes pero NO los envía | false = envía de verdad
CHAT_DRY_RUN=false

# true = responde todas las conversaciones pendientes por ciclo
CHAT_REPLY_ALL=false

# Segundos de espera después de escribir, antes de confirmar el envío
CHAT_SEND_DELAY_S=0

# Máximo de conversaciones a revisar por ciclo de chat
CHAT_MAX_CONVERSATIONS=10

# Minutos entre ciclos de chat (modo Chat puro)
CHAT_CYCLE_MIN_MIN=0
CHAT_CYCLE_MAX_MIN=0
